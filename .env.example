REGION_A='265,497'
REGION_B='1124,561'
REGION_C='1128,456'
REGION_D='25,346'
HKV_IP=192.168.7.54
HKV_USER=admin
HKV_PASS=abcd1234
HKV_SNAPSHOT_URL=http://{ip}/cgi-bin/snapshot.cgi?channel=1&subtype=0

ALPR_DETECTOR_MODEL=yolo-v9-t-640-license-plate-end2end
ALPR_OCR_MODEL=cct-xs-v1-global-model
PLATE_STREAM_MODEL=license-plate-finetune-v1n_openvino_model
PLATE_DETECTOR_ONNX=license-plate-finetune-v1n_openvino_model
PLATE_OCR_MODEL=cct-xs-v1-global-model
PLATE_DETECTOR_CONF=0.25

DEFAULT_MODEL=license-plate-finetune-v1n_openvino_model

# Skip frame: số frame bỏ qua giữa mỗi lần inference (mặc định: 2)
# Đặt SKIP_FRAMES=1 để xử lý mọi frame (không bỏ qua), tốn CPU hơn
SKIP_FRAMES=1

# Nhận dạng biển số (ALPR): true = chụp ảnh & nhận dạng khi xe vào vùng
# false = chỉ phát hiện xe vào vùng + gửi vehicle_enter socket, không chụp/nhận dạng
ENABLE_ALPR=false

# Số giây tối thiểu xe phải ở trong vùng để được tính là "đậu xe" (mặc định: 2 giây)
REGION_DWELL_SECONDS=2

# Chế độ kiểm tra biển số với vùng nhận diện (mặc định: contain)
# contain   = toàn bộ bounding box biển số phải nằm hoàn toàn trong vùng
# intersect = bounding box biển số chỉ cần giao cắt/chạm vào vùng là đủ
REGION_TRIGGER_MODE=contain